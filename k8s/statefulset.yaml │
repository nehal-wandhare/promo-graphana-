apiVersion: apps/v1
kind: StatefulSet
metadata:
  name: frontend-stateful
spec:
  serviceName: "frontend"
  replicas: 2
  selector:
    matchLabels:
      app: frontend
  template:
    metadata:
      labels:
        app: frontend
    spec:
      containers:
      - name: frontend
        image: nehalwandhare/devops-portfolio